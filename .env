# --- Executor (Render Frankfurt) ---
# Gitignored worksheet + local-run config. For Render, paste these into the
# service's Environment tab (the sync:false ones in render.yaml).

# Auth (must match the Brain's EXECUTOR_TOKEN)
EXECUTOR_TOKEN=31796444248f1b767da0e8db1c2cc42b

# Live feed -> Brain (executor polls Binance, forwards {row,chain} to the brain).
BRAIN_URL=https://hugfacmaster-btc-consensus-brain.hf.space
WEBHOOK_TOKEN=899a1078fd180f6f739356c32cdf19ed
POLL_INTERVAL=60
SKIP_SAME_DAY_EXPIRY=true
MIN_EXPIRY_HOURS=3

# Safety: starts in dry-run. Flip to live with POST /admin/mode {"live":true}
LIVE=false

# Binance options API (eapi-enabled key with trade permission). Only used in LIVE.
BINANCE_API_KEY=<ONLY_NEEDED_FOR_LIVE>
BINANCE_API_SECRET=<ONLY_NEEDED_FOR_LIVE>
BINANCE_EAPI=https://eapi.binance.com
BINANCE_RECV_WINDOW=5000
REPRICE_AT_ORDER=true        # fetch a fresh Binance mark to price/validate each order

# Risk controls
MAX_OPEN_PER_STRATEGY=1
MAX_OPEN_TOTAL=12
DAILY_LOSS_LIMIT=0
