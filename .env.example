# --- Executor (Render Frankfurt, or any non-US region) ---

# Auth (must match the Brain's EXECUTOR_TOKEN)
EXECUTOR_TOKEN=executor-secret

# Live feed -> Brain: the executor polls Binance and forwards {row,chain} to the
# brain (the HF brain is geo-blocked from Binance). Empty BRAIN_URL = feed off.
BRAIN_URL=https://your-brain.hf.space
WEBHOOK_TOKEN=shared-secret          # must match the brain's WEBHOOK_TOKEN
POLL_INTERVAL=60
SKIP_SAME_DAY_EXPIRY=true
MIN_EXPIRY_HOURS=3

# Safety: starts in dry-run. Flip to live with POST /admin/mode {"live":true}
# (no redeploy) once you've confirmed dry-run orders look correct.
LIVE=false

# Binance options API (eapi-enabled key with trade permission). Only used in LIVE.
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_EAPI=https://eapi.binance.com
BINANCE_RECV_WINDOW=5000
REPRICE_AT_ORDER=true        # fetch a fresh Binance mark to price/validate each order

# Risk controls
MAX_OPEN_PER_STRATEGY=1
MAX_OPEN_TOTAL=12
DAILY_LOSS_LIMIT=0            # USDT; 0 = disabled. Hitting it auto-halts.
